{
  "name": "adaptive-coach-app",
  "version": "1.0.0",
  "description": "Adaptive physiotherapy and training coach app scaffold",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "node --test test/*.test.js",
    "test:watch": "node --test --watch",
    "lint": "node --check src/*.js test/*.js mobile/src/*.mjs mobile/test/*.mjs",
    "mobile:install": "NPM_CONFIG_CACHE=.npm-cache npm --prefix mobile install --include=dev",
    "mobile:start": "npm --prefix mobile run start",
    "mobile:test": "npm --prefix mobile run test",
    "mobile:verify": "npm --prefix mobile run verify",
    "test:all": "npm test && npm run mobile:test",
    "ios:run": "node scripts/ios-run.mjs",
    "ios:run:expo": "npm --prefix mobile run ios:run:expo",
    "ios:maestro:prepare": "node scripts/ios-maestro-prepare.mjs",
    "ios:maestro:test": "maestro -p ios test mobile/.maestro --format junit --output mobile/.derived-data/maestro/results.xml --test-output-dir mobile/.derived-data/maestro/artifacts --debug-output mobile/.derived-data/maestro/debug --flatten-debug-output",
    "ios:maestro:teardown": "node scripts/ios-maestro-teardown.mjs",
    "e2e:maestro": "node scripts/ios-maestro-session.mjs"
  },
  "keywords": [
    "physiotherapy",
    "fitness",
    "adaptive-training"
  ],
  "author": "",
  "license": "MIT"
}
