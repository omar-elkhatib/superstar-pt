{
  "name": "superstar-pt-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "web": "expo start --web",
    "test:logic": "node --test test/*.test.mjs",
    "test:config": "node --test test/projectConfig.test.mjs",
    "test": "npm run test:logic && npm run test:config",
    "doctor": "expo config --json > /dev/null",
    "bundle:ios": "expo export --platform ios --output-dir dist --clear",
    "verify": "npm run test && npm run doctor && npm run bundle:ios"
  },
  "dependencies": {
    "@react-navigation/bottom-tabs": "^7.0.0",
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/native-stack": "^7.0.0",
    "expo": "~54.0.0",
    "expo-haptics": "^55.0.8",
    "expo-status-bar": "~3.0.8",
    "react": "19.1.0",
    "react-native": "0.81.4",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0"
  }
}
